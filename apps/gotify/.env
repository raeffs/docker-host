
# *****************************************************************************
# Gotify
# *****************************************************************************

# Public domain name for Gotify.
# GOTIFY_DOMAIN='gotify.my-domain.ch'

# Server where the Gotify PostgreSQL database is located.
# GOTIFY_POSTGRES_SERVER=''

# User used to connect to the Gotify PostgreSQL database.
# GOTIFY_POSTGRES_USER=''

# Password used to connect to the Gotify PostgreSQL database.
# GOTIFY_POSTGRES_PASSWORD=''

# Name of the Gotify PostgreSQL database.
# GOTIFY_POSTGRES_DATABASE=''

# Port used to connect to the Gotify PostgreSQL database.
GOTIFY_POSTGRES_PORT='5432'
