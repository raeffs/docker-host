
# *****************************************************************************
# Pocket ID
# *****************************************************************************

# Set to true to disable the automatic version check against GitHub.
VERSION_CHECK_DISABLED='true'

# Disable heartbeat that gets sent every 24 hours to count how many Pocket ID instances are running.
ANALYTICS_DISABLED='true'

# Enable configuration via environment variables.
UI_CONFIG_DISABLED='true'

# The name of the app.
APP_NAME='ID'

# A custom accent color for the UI.
ACCENT_COLOR='#1e66f5'

# Whether the users should be able to edit their own account details.
ALLOW_OWN_ACCOUNT_EDIT='false'
