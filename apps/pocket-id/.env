
# *****************************************************************************
# Pocket ID
# *****************************************************************************

# Public domain name for Pocket ID.
# POCKET_ID_DOMAIN='pocket-id.my-domain.ch'

# Key used to encrypt data, including the private keys. It's recommended to use a random sequence of characters, for example generated with `openssl rand -base64 32`.
# POCKET_ID_ENCRYPTION_KEY='random-key'

# Server where the Pocket ID PostgreSQL database is located.
# POCKET_ID_POSTGRES_SERVER=''

# User used to connect to the Pocket ID PostgreSQL database.
# POCKET_ID_POSTGRES_USER=''

# Password used to connect to the Pocket ID PostgreSQL database.
# POCKET_ID_POSTGRES_PASSWORD=''

# Name of the Pocket ID PostgreSQL database.
# POCKET_ID_POSTGRES_DATABASE=''

# Port used to connect to the Pocket ID PostgreSQL database.
POCKET_ID_POSTGRES_PORT='5432'
