{
  "name": "commento",
  "implicitDependencies": ["networks", "traefik"],
  "targets": {
    "create-volumes": {
      "options": {
        "volumes": ["commento-db"]
      }
    },
    "create-variables": {
      "options": {
        "variables": [
          {
            "name": "COMMENTO_POSTGRES_PASSWORD",
            "description": "Password of the Commento PostgreSQL database."
          }
        ]
      }
    }
  }
}
