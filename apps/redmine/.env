# *****************************************************************************
# Redmine
# *****************************************************************************

# Public domain name for Redmine.
# REDMINE_DOMAIN='redmine.my-domain.ch'

# Server where the Redmine PostgreSQL database is located.
# REDMINE_POSTGRES_SERVER=''

# User used to connect to the Redmine PostgreSQL database.
# REDMINE_POSTGRES_USER=''

# Password used to connect to the Redmine PostgreSQL database.
# REDMINE_POSTGRES_PASSWORD=''

# Name of the Redmine PostgreSQL database.
# REDMINE_POSTGRES_DATABASE=''

# SMTP server used by Redmine to send emails.
# REDMINE_SMTP_HOST=''

# SMTP login used by Redmine to send emails.
# REDMINE_SMTP_USER=''

# SMTP password used by Redmine to send emails.
# REDMINE_SMTP_PASSWORD=''

# Port used to connect to the Redmine PostgreSQL database.
REDMINE_POSTGRES_PORT='5432'

# SMTP port used by Redmine to send emails.
REDMINE_SMTP_PORT='587'
