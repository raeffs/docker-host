{
  "name": "baikal",
  "implicitDependencies": ["networks", "traefik"],
  "targets": {
    "create-volumes": {
      "options": {
        "volumes": ["baikal-data", "baikal-config"]
      }
    },
    "create-variables": {
      "options": {
        "variables": [
          {
            "name": "BAIKAL_DOMAIN",
            "description": "Public domain name for Baikal.",
            "defaultValue": "baikal.${DEFAULT_DOMAIN_SUFFIX}"
          }
        ]
      }
    }
  }
}
