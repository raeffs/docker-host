{
  "$schema": "http://json-schema.org/schema",
  "version": 2,
  "type": "object",
  "properties": {
    "detach": {
      "type": "boolean",
      "default": true
    },
    "force": {
      "type": "boolean",
      "default": false
    },
    "wait": {
      "type": "boolean",
      "default": false
    },
    "waitTimeout": {
      "type": "number",
      "default": 120
    }
  }
}
