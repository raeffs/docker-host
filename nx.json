{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "plugins": [
    {
      "options": {},
      "plugin": "@raeffs/docker-compose"
    }
  ],
  "targetDefaults": {
    "@nx/eslint:lint": {
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/eslint.config.mjs"
      ]
    },
    "build": {
      "cache": true,
      "dependsOn": [
        "^build"
      ]
    }
  },
  "tui": {
    "enabled": false
  },
  "useInferencePlugins": false
}