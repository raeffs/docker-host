{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "pinDigests": false
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/bower_components/**", "archive"]
}
