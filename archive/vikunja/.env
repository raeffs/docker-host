# *****************************************************************************
# Vikunja
# *****************************************************************************

# Public domain name for Vikunja.
# VIKUNJA_DOMAIN='vikunja.my-domain.ch'

# Server where the Vikunja PostgreSQL database is located.
# VIKUNJA_POSTGRES_SERVER=''

# User used to connect to the Vikunja PostgreSQL database.
# VIKUNJA_POSTGRES_USER=''

# Password used to connect to the Vikunja PostgreSQL database.
# VIKUNJA_POSTGRES_PASSWORD=''

# Name of the Vikunja PostgreSQL database.
# VIKUNJA_POSTGRES_DATABASE=''

# Issuer URL of the Pocket ID instance used for OpenID Connect login.
# VIKUNJA_OIDC_AUTH_URL='https://pocket-id.my-domain.ch'

# Client ID of the Vikunja OIDC client in Pocket ID.
# VIKUNJA_OIDC_CLIENT_ID=''

# Client secret of the Vikunja OIDC client in Pocket ID.
# VIKUNJA_OIDC_CLIENT_SECRET=''

# Port used to connect to the Vikunja PostgreSQL database.
VIKUNJA_POSTGRES_PORT='5432'
