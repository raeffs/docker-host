{
  "name": "home-assistant",
  "implicitDependencies": ["networks", "traefik"],
  "targets": {
    "create-volumes": {
      "options": {
        "volumes": ["home-assistant-data", "home-assistant-db"]
      }
    },
    "create-variables": {
      "options": {
        "variables": [
          {
            "name": "HA_MYSQL_PASSWORD",
            "description": "Password of the Home Assistant MySQL database."
          }
        ]
      }
    }
  }
}
